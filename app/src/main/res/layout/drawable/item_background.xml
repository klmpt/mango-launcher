<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http:
    <!-- Когда на приложение нажали пальцем -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#2A1B10" />
            <corners android:radius="16dp" />
            <stroke android:width="1.5dp" android:color="#FF6B00" />
        </shape>
    </item>
    
    <!-- Обычное состояние плитки в списке -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#121216" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#1A1A22" />
        </shape>
    </item>
</selector>